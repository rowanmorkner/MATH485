smoker <-  read.table("http://emersonstatistics.com/Datasets/fev.txt")
library(knitr)
library(dplyr)
View(smoker)
typof(smoker)
typ_of(smoker)
type_of(smoker)
typeof(smoker)
smoker <- as.data.frame(smoker)
typeof(smoker)
smoker <- as.data.frame(smoker)
kable(head(smoker))
lm_smoker <- lm(fev ~ height + age + smoke, data = smoker)
smoker <-  read.table("http://emersonstatistics.com/Datasets/fev.txt", head= TRUE)
lm_smoker <- lm(fev ~ height + age + smoke, data = smoker)
lm_smoker <- lm(fev ~ height + age + smoke + sex, data = smoker)
summary(lm_smoker)
lm_smoker <- lm(fev ~ height + age + smoke, data = smoker)
summary(lm_smoker)
lm_smoker <- lm(fev ~ height + age + smoke + sex, data = smoker)
summary(lm_smoker)
df <- data.frame(
label = c(4.93, 5.41, 4.94, 4.93, 5.62, 4.8, 5.51),
actual = c(1.83, 2.32, 1.84, 1.83, 2.53, 1.71, 2.41)
)
View(df)
df_fit <- lm(actual ~ label, data = df)
summary(df_fit)
library(ggplot2)
library(ggplot2)
ggplot(df, aes(x = label, y = actual)) +
geom_point() +
geom_smooth(method = "lm", se = FALSE, color = "blue") +
labs(title = "Scatter Plot with Regression Line",
x = "Label",
y = "Actual")
df_fit <- lm(label ~ actual, data = df)
summary(df_fit)
ggplot(df, aes(x = actual, y = label)) +
geom_point() +
geom_smooth(method = "lm", se = FALSE, color = "blue") +
labs(title = "Scatter Plot with Regression Line",
x = "Label",
y = "Actual")
